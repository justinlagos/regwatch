# Root-level environment example
# Copy this to .env and fill in your values
# Never commit .env files — they are gitignored

# See apps/web/.env.example for web app environment variables
# See supabase/functions for edge function secrets (set via Supabase CLI)

# Supabase edge function secrets (set with: supabase secrets set KEY=value)
# OPENAI_API_KEY=<your-openai-key>
# RESEND_API_KEY=<your-resend-key>
# CRON_SECRET=<random-hex-secret>
